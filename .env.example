# ==========================================================
# WatchLink — Environment variables example
# Copy this file:
#   - Backend:  cp .env.example apps/server/.env
#   - Frontend: cp .env.example apps/web/.env.local
# Then fill in real values. NEVER commit your real .env files.
# ==========================================================

# ---------------------- BACKEND (apps/server/.env) ----------------------
NODE_ENV=development
PORT=4000

# MongoDB connection string (local or MongoDB Atlas)
# Local example:  mongodb://127.0.0.1:27017/watchlink
# Atlas example:  mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/watchlink
MONGODB_URI=mongodb://127.0.0.1:27017/watchlink

# JWT — use a long random string in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Where the frontend is served from (used for CORS)
CLIENT_URL=http://localhost:3000

# Room lifecycle
ROOM_EXPIRATION_HOURS=12
MAX_ROOM_PARTICIPANTS=20

# WebRTC ICE servers (used in phase 4). STUN is public; TURN is your own/3rd-party.
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ---------------------- FRONTEND (apps/web/.env.local) ----------------------
# Public values are exposed to the browser — keep secrets OUT of these.
# Canonical site URL — used for SEO metadata (canonical links, Open Graph). In
# production set this to your real domain, e.g. https://watchlink.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
# Optional TURN relay for cross-NAT voice (leave blank to use STUN only).
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_PASSWORD=
